<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Us | Currentify</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/dropdown.css">
    <link rel="stylesheet" href="/css/contact.css">
    <link rel="stylesheet" href="/css/footer.css">
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>

    <%- include('partials/header') %>

    <main class="contact-wrapper">

        <!-- ═══ HERO ═══ -->
        <section class="contact-hero">
            <div class="hero-bg-grid"></div>
            <div class="hero-glow"></div>
            <div class="contact-hero-inner">
                <span class="hero-kicker">
                    <i class="fa-solid fa-satellite-dish"></i>
                    We're listening
                </span>
                <h1>Get in Touch</h1>
                <p>Have a news tip, a technical query, or a partnership proposal? We're here to listen.</p>
            </div>
        </section>

        <!-- ═══ MAIN CARD ═══ -->
        <section class="contact-container">

            <!-- LEFT: Contact Info Panel -->
            <div class="contact-info">
                <!-- Decorative orbs -->
                <div class="info-orb info-orb--1"></div>
                <div class="info-orb info-orb--2"></div>

                <div class="info-panel-content">
                    <h2>Contact Information</h2>
                    <p class="info-tagline">Fill out the form and our team will get back to you within 24 hours.</p>

                    <div class="info-details">
                        <div class="info-item">
                            <span class="icon">
                                <i class="fa-solid fa-envelope"></i>
                            </span>
                            <div>
                                <h3>Email Us</h3>
                                <p>support@currentify.com</p>
                            </div>
                        </div>

                        <div class="info-item">
                            <span class="icon">
                                <i class="fa-solid fa-location-dot"></i>
                            </span>
                            <div>
                                <h3>Location</h3>
                                <p>Lahore, Pakistan</p>
                            </div>
                        </div>
                    </div>

                    <div class="social-links">
                        <h3>Follow the Pulse</h3>
                        <div class="social-icons">
                            <a href="#" aria-label="Facebook">
                                <i class="fa-brands fa-facebook-f"></i>
                            </a>
                            <a href="#" aria-label="X / Twitter">
                                <i class="fa-brands fa-x-twitter"></i>
                            </a>
                            <a href="#" aria-label="Instagram">
                                <i class="fa-brands fa-instagram"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- RIGHT: Form Panel -->
            <div class="contact-form-box">
                <div class="form-header">
                    <h2>Send us a message</h2>
                    <p>We'll get back to you within one business day.</p>
                </div>

                <form action="/contact" method="POST">
                    <div class="form-row">
                        <div class="form-group">
                            <label for="contact-name">Full Name</label>
                            <div class="input-wrap">
                                <i class="fa-solid fa-user input-icon"></i>
                                <input type="text" id="contact-name" name="name" placeholder="John Doe" required>
                            </div>
                        </div>
                        <div class="form-group">
                            <label for="contact-email">Email Address</label>
                            <div class="input-wrap">
                                <i class="fa-solid fa-envelope input-icon"></i>
                                <input type="email" id="contact-email" name="email" placeholder="john@example.com" required>
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="contact-subject">Subject</label>
                        <div class="input-wrap input-wrap--select">
                            <i class="fa-solid fa-tag input-icon"></i>
                            <select id="contact-subject" name="subject">
                                <option value="News Tip">Submit a News Tip</option>
                                <option value="Technical Support">Technical Support</option>
                                <option value="Advertising">Advertising &amp; Partnerships</option>
                                <option value="Other">Other</option>
                            </select>
                            <i class="fa-solid fa-chevron-down select-arrow"></i>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="contact-message">Message</label>
                        <div class="input-wrap input-wrap--textarea">
                            <textarea id="contact-message" name="message" rows="6" placeholder="How can we help you?" required></textarea>
                        </div>
                    </div>

                    <div class="form-footer">
                        <p class="form-note">
                            <i class="fa-solid fa-lock"></i>
                            Your information is kept private and never shared.
                        </p>
                        <button type="submit" class="btn-send">
                            Send Message
                            <i class="fa-solid fa-paper-plane"></i>
                        </button>
                    </div>
                </form>
            </div>

        </section>
    </main>

    <%- include('partials/footer') %>

</body>
</html>
