<div id="postSidebar" class="sidebar">
    <div class="sidebar-header">
        <span id="sidebarCategory" class="sidebar-category-label"></span>
        <button id="closeSidebar" type="button" class="close-btn" aria-label="Close sidebar">&times;</button>
    </div>

    <div class="sidebar-content">
        <div id="sidebarImageContainer"></div>
        <div id="sidebarTextContainer">
            <h2 id="sidebarTitle"></h2>
            <p id="sidebarDate" class="post-meta"></p>
            <div id="sidebarBody"></div>
        </div>
        <div id="sidebarReferences" style="margin: 0 20px 20px 20px; padding: 15px; background: #f8fafc; border-radius: 8px; border-left: 4px solid #3b82f6; display: none;">
            <h4 style="margin: 0 0 8px 0; color: #1e293b; font-size: 0.9rem;"> References</h4>
            <p id="sidebarReferencesText" style="margin: 0; color: #475569; font-size: 0.85rem; white-space: pre-line;"></p>
        </div>
    </div>
</div>
<div id="sidebarOverlay" class="sidebar-overlay"></div>