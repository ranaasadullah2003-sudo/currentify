<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>About Us | Currentify</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/dropdown.css">
    <link rel="stylesheet" href="/css/about.css">
    <link rel="stylesheet" href="/css/footer.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

    <%- include('partials/header') %>

    <main class="about-wrapper">

        <!-- ═══════════════ HERO ═══════════════ -->
        <section class="about-hero-v2">
            <div class="hero-overlay"></div>
            <div class="hero-mesh"></div>
            <div class="hero-text-container">
                <span class="eyebrow">Established 2026</span>
                <h1>Redefining the <span class="highlight">Digital News</span> Landscape</h1>
                <p>Currentify isn't just a news portal; it's a hub for clarity in an age of information overload.</p>
            </div>
            <div class="hero-scroll-hint">
                <span>Scroll</span>
                <div class="scroll-line"></div>
            </div>
        </section>

        <!-- ═══════════════ MISSION ═══════════════ -->
        <section class="mission-section">
            <div class="mission-container">
                <div class="mission-image">
                    <div class="abstract-shape"></div>
                    <img src="https://images.unsplash.com/photo-1451187580459-43490279c0fa?q=80&w=1000" alt="Technology and Data">
                </div>
                <div class="mission-text">
                    <span class="section-kicker">Our Purpose</span>
                    <h2>Our Mission</h2>
                    <p>
                        We believe that news should be more than just headlines. At Currentify, we utilize
                        modern web technologies to bridge the gap between complex <strong>Environmental Legislation</strong>
                        and public understanding.
                    </p>
                    <p>
                        Our platform is built by developers and researchers dedicated to high-fidelity reporting,
                        ensuring that every article—from global politics to specialized IT innovation—is
                        backed by data and technical expertise.
                    </p>
                    <div class="mission-stat-row">
                        <div class="mission-stat">
                            <span class="stat-num">100%</span>
                            <span class="stat-label">Source-cited</span>
                        </div>
                        <div class="mission-stat">
                            <span class="stat-num">4+</span>
                            <span class="stat-label">Focus areas</span>
                        </div>
                        <div class="mission-stat">
                            <span class="stat-num">2026</span>
                            <span class="stat-label">Founded</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ═══════════════ WHO WE ARE ═══════════════ -->
        <section class="who-we-are">
            <div class="section-header">
                <span class="section-kicker">The Team</span>
                <h2>Who We Are</h2>
                <div class="underline"></div>
            </div>
            <div class="who-container">
                <p>
                    Currentify was founded by a team of developers and researchers who saw a gap
                    between complex information and public understanding. We're not journalists by
                    trade — we're technologists who believe in clear, well-sourced, and honest writing.
                </p>
                <p>
                    Every article on this site is researched, written, and fact-checked with care.
                    We cite our sources so you can verify the information yourself.
                </p>
            </div>
        </section>

        <!-- ═══════════════ VALUES ═══════════════ -->
        <section class="values-section">
            <div class="section-header">
                <span class="section-kicker">Our Principles</span>
                <h2>What We Stand For</h2>
                <div class="underline"></div>
            </div>
            <div class="values-grid">
                <div class="value-card">
                    <div class="value-icon">
                        <i class="fa-solid fa-check-circle"></i>
                    </div>
                    <h3>Accuracy</h3>
                    <p>Every fact is verified. Every source is cited. We prioritize truth over speed.</p>
                </div>
                <div class="value-card">
                    <div class="value-icon">
                        <i class="fa-solid fa-lightbulb"></i>
                    </div>
                    <h3>Clarity</h3>
                    <p>Complex topics explained simply. No jargon, no noise — just clear understanding.</p>
                </div>
                <div class="value-card">
                    <div class="value-icon">
                        <i class="fa-solid fa-lock-open"></i>
                    </div>
                    <h3>Independence</h3>
                    <p>We're independently run. No corporate agenda, no clickbait — just honest writing.</p>
                </div>
                <div class="value-card">
                    <div class="value-icon">
                        <i class="fa-solid fa-globe-americas"></i>
                    </div>
                    <h3>Curiosity</h3>
                    <p>We cover what fascinates us — politics, tech, science, sports, and the ideas shaping our world.</p>
                </div>
            </div>
        </section>

        <!-- ═══════════════ HOW WE WORK ═══════════════ -->
        <section class="how-we-work">
            <div class="section-header">
                <span class="section-kicker">Our Process</span>
                <h2>How We Work</h2>
                <div class="underline"></div>
            </div>
            <div class="process-steps">
                <div class="step">
                    <div class="step-number">01</div>
                    <h3>Research</h3>
                    <p>We dig into the topic, gathering information from credible sources across the web. We cross-check facts, compare perspectives, and pull from trusted publications, official reports, and expert analysis. No single source tells the whole story — so we consult many.</p>
                </div>
                <div class="step">
                    <div class="step-number">02</div>
                    <h3>Write</h3>
                    <p>We craft clear, engaging articles that explain the story — not just repeat headlines. We break down complex ideas into plain language, add context where it's missing, and structure every piece so it's easy to follow. No fluff, no filler — just useful information.</p>
                </div>
                <div class="step">
                    <div class="step-number">03</div>
                    <h3>Cite</h3>
                    <p>Every article includes references. You can trace every claim back to its source. We believe transparency builds trust, so we link directly to the original material. If we can't verify it, we don't publish it.</p>
                </div>
                <div class="step">
                    <div class="step-number">04</div>
                    <h3>Publish</h3>
                    <p>Every article includes references. You can trace every claim back to its source. We believe transparency builds trust, so we link directly to the original material. If we can't verify it, we don't publish it.</p>
                </div>
            </div>
        </section>

        <!-- ═══════════════ EXPERTISE ═══════════════ -->
        <section class="expertise-section">
            <div class="section-header">
                <span class="section-kicker">What We Cover</span>
                <h2>Our Specialized Focus</h2>
                <div class="underline"></div>
            </div>
            <div class="expertise-grid">
                <div class="expertise-card">
                    <div class="card-icon">
                        <i class="fa-solid fa-scale-balanced"></i>
                    </div>
                    <h3>Environmental Law</h3>
                    <p>Deep-dive analysis into Pakistani and International environmental protection acts.</p>
                </div>
                <div class="expertise-card">
                    <div class="card-icon">
                        <i class="fa-solid fa-satellite"></i>
                    </div>
                    <h3>GIS and Tech</h3>
                    <p>Exploring the power of Web GIS Mapping and microcontroller-driven assistance hardware.</p>
                </div>
                <div class="expertise-card">
                    <div class="card-icon">
                        <i class="fa-solid fa-trophy"></i>
                    </div>
                    <h3>Sports Analytics</h3>
                    <p>Providing modern coverage and rule-sets for major Football and Cricket leagues.</p>
                </div>
                <div class="expertise-card">
                    <div class="card-icon">
                        <i class="fa-solid fa-shield-halved"></i>
                    </div>
                    <h3>Global Policy</h3>
                    <p>Unbiased reporting on international diplomacy and legislative shifts across the globe.</p>
                </div>
            </div>
        </section>

        <!-- ═══════════════ CTA ═══════════════ -->
        <section class="about-cta">
            <div class="cta-inner">
                <span class="section-kicker cta-kicker">Stay Informed</span>
                <h2>Join the conversation.</h2>
                <p>Explore our latest reports and stay informed with Currentify.</p>
                <a href="/" class="btn-primary">Browse Latest Updates</a>
            </div>
        </section>

    </main>

    <%- include('partials/footer') %>

</body>
</html>
